# Database (MySQL) — di Railway, klik "Add Reference" ke service MySQL kamu
DATABASE_URL="mysql://user:password@localhost:3306/desa_tanjungsari"

# Auth.js — ganti dengan domain Railway kamu, generate secret pakai: openssl rand -base64 32
NEXTAUTH_URL="https://nama-project-kamu.up.railway.app"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Site
NEXT_PUBLIC_SITE_URL="https://nama-project-kamu.up.railway.app"
NEXT_PUBLIC_SITE_NAME="Desa Tanjungsari"
NEXT_PUBLIC_KECAMATAN="Jenangan"
NEXT_PUBLIC_KABUPATEN="Ponorogo"

# AI Assistant — Gemini API key GRATIS dari Google AI Studio
# Ambil di: https://aistudio.google.com/apikey
GEMINI_API_KEY="AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# Model default: gemini-2.5-flash-lite (RPM/RPD paling longgar di free tier)
GEMINI_MODEL="gemini-2.5-flash-lite"
# Rate limiter internal — jaga-jaga di bawah limit resmi Google supaya gak 429
GEMINI_RPM_LIMIT="10"
GEMINI_RPD_LIMIT="1400"

# Search Engine (opsional) — buat fitur "cek berita terbaru yang belum ada di web sendiri"
# Pakai Google Programmable Search Engine (free tier 100 query/hari, no credit card):
# 1. Buat search engine di https://programmablesearchengine.google.com (scope: seluruh web)
# 2. Aktifkan "Custom Search API" & ambil API key di https://console.cloud.google.com
GOOGLE_CSE_API_KEY=""
GOOGLE_CSE_CX=""
# Kuota harian dibatasi sendiri di aplikasi, di bawah limit gratis 100/hari
SEARCH_ENGINE_DAILY_LIMIT="90"

# Upload gambar — Cloudinary (free tier: 25GB storage, 25GB bandwidth/bulan)
# Ambil di dashboard Cloudinary: https://console.cloudinary.com
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
MAX_UPLOAD_SIZE_MB="5"
